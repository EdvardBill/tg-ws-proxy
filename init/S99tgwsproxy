#!/bin/sh
SECRET=$(cat /opt/home/admin/proxy_secret.txt 2>/dev/null)
PORT=$(cat /opt/home/admin/proxy_port.txt 2>/dev/null)
HOST=$(cat /opt/home/admin/proxy_host.txt 2>/dev/null)
[ -z "$PORT" ] && PORT=1443
[ -z "$HOST" ] && HOST="0.0.0.0"
cd /opt/home/admin/tg-ws-proxy

start() {
    stop
    CURRENT_PORT=$(cat /opt/home/admin/proxy_port.txt 2>/dev/null)
    [ -z "$CURRENT_PORT" ] && CURRENT_PORT=1443
    if netstat -tuln 2>/dev/null | grep -q ":${CURRENT_PORT} "; then
        echo "Port $CURRENT_PORT is busy, killing..."
        fuser -k ${CURRENT_PORT}/tcp 2>/dev/null
        sleep 2
    fi
    echo "Starting proxy on $HOST:$CURRENT_PORT..."
    python3 -m proxy.tg_ws_proxy --host "$HOST" --port "$CURRENT_PORT" --secret "$SECRET" > /var/log/tg-ws-proxy.log 2>&1 &
    sleep 3
    if pgrep -f "proxy.tg_ws_proxy" > /dev/null; then
        PID=$(pgrep -f "proxy.tg_ws_proxy" | head -1)
        echo "$PID" > /var/run/tg-ws-proxy.pid
        echo "Started with PID: $PID"
        return 0
    else
        echo "Failed to start. Check log: /var/log/tg-ws-proxy.log"
        return 1
    fi
}
stop() {
    CURRENT_PORT=$(cat /opt/home/admin/proxy_port.txt 2>/dev/null)
    [ -z "$CURRENT_PORT" ] && CURRENT_PORT=1443
    if [ -f /var/run/tg-ws-proxy.pid ]; then
        kill -9 $(cat /var/run/tg-ws-proxy.pid) 2>/dev/null
        rm -f /var/run/tg-ws-proxy.pid
    fi
    pkill -9 -f "proxy.tg_ws_proxy" 2>/dev/null
    fuser -k ${CURRENT_PORT}/tcp 2>/dev/null
    echo "Stopped"
}
case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 2; start ;;
    *) exit 1 ;;
esac